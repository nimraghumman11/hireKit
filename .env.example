# Database
# For Docker Compose: the backend image builds DATABASE_URL from POSTGRES_* (see backend/docker-entrypoint.sh).
# You may omit DATABASE_URL in .env for Compose, or keep a localhost URL only for running the backend with npm on the host.
# Compose maps Postgres to host port 5433 (see docker-compose.yml) so tools on Windows (e.g. pgAdmin) do not hit a separate local PostgreSQL on 5432.
# If the password contains @, encode it as %40 inside DATABASE_URL (e.g. p@ss -> p%40ss).
DATABASE_URL=postgresql://interview_kit:secret@localhost:5433/interview_kit
POSTGRES_USER=interview_kit
POSTGRES_PASSWORD=secret
POSTGRES_DB=interview_kit

# Auth
JWT_SECRET=change_me_to_a_strong_random_secret_at_least_32_chars

# AI Service
AI_SERVICE_URL=http://localhost:8000
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# PDF Storage (local disk, served via FastAPI StaticFiles)
PDF_STORAGE_PATH=./data/pdfs
AI_SERVICE_BASE_URL=http://localhost:8000

# Frontend (Vite)
VITE_API_URL=http://localhost:3000
